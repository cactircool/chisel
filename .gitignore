# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binaries
*_test

# Editor/IDE specific files
.idea/
.vscode/
*.swp
*.bak
*.log

# Build artifacts and caches
/bin/
/pkg/
/tmp/
/build/
*.out
